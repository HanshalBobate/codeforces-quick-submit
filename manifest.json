{
    "manifest_version": 3,
    "name": "Codeforces Quick Submit",
    "short_name": "CF Quick Submit",
    "version": "1.0.0",
    "description": "Adds a native Quick Submit button to Codeforces problem pages and automatically fills the submission form.",
    "author": "Hanshal",
    "homepage_url": "https://github.com/yourusername/cf-quick-submit",

    "permissions": [
        "storage"
    ],

    "icons": {
        "16": "icons/icon16.png",
        "32": "icons/icon32.png",
        "48": "icons/icon48.png",
        "128": "icons/icon128.png"
    },

    "content_scripts": [{
            "matches": [
                "https://codeforces.com/problemset/problem/*"
            ],
            "js": [
                "content.js"
            ]
        },
        {
            "matches": [
                "https://codeforces.com/problemset/problem/*",
                "https://codeforces.com/contest/*/problem/*",
                "https://codeforces.com/gym/*/problem/*"
            ],
            "js": [
                "submit.js"
            ]
        }
    ]
}